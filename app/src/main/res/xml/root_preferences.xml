<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory android:title="@string/pref_category_silence">

        <!--
            Stored as int 5–100.
            In SilenceDetector: threshold = value / 1000f  →  0.005–0.100 normalised RMS
        -->
        <SeekBarPreference
            android:key="silence_threshold"
            android:title="@string/pref_silence_threshold_title"
            android:summary="@string/pref_silence_threshold_summary"
            android:defaultValue="20"
            android:min="5"
            android:max="100"
            app:showSeekBarValue="true" />

        <!--
            Stored as int 500–3000 (milliseconds).
        -->
        <SeekBarPreference
            android:key="silence_duration_ms"
            android:title="@string/pref_silence_duration_title"
            android:summary="@string/pref_silence_duration_summary"
            android:defaultValue="1500"
            android:min="500"
            android:max="3000"
            app:showSeekBarValue="true" />

    </PreferenceCategory>

</PreferenceScreen>
